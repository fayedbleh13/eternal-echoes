# ========================================================
# Eternal Echoes - Environment Variables Template
# Copy this file to .env and fill in the actual values.
# ========================================================

# --- BACKEND (apps/server) ---

# Port for the Express server to listen on.
PORT=4000

# MongoDB URI (Atlas Connection String)
# Example: mongodb+srv://<username>:<password>@cluster0.exmpl.mongodb.net/eternalechoes?retryWrites=true&w=majority
MONGODB_URI=

# Better Auth - Base URL (Important for callback validation)
BETTER_AUTH_URL=http://localhost:4000
BETTER_AUTH_SECRET=

# Google OAuth Credentials (for Better Auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudinary Integration (Media Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini Flash Integration ("Echo" Ghost Writer)
GEMINI_API_KEY=

# Resend Email API (for sending capsule notifications)
# Get your API key from: https://resend.com
RESEND_API_KEY=

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000


# --- FRONTEND (apps/web) ---

# Better Auth URL (must be prefixed with VITE_ for client-side access)
BETTER_AUTH_URL=http://localhost:4000

# The URL the frontend will use to fetch the GraphQL API.
VITE_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

